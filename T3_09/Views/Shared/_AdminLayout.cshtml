<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</head>
<body>
    <div class="d-flex">
        <nav class="bg-dark text-white p-3" style="width: 250px; height: 100vh;">
            <h4 class="text-center">Panel Admininstracion</h4>
            <ul class="nav flex-column mt-4">
                <li class="nav-item">
                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link text-white">
                        <i class="bi bi-bar-chart-line"></i> Dashboards
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Estudiantes" asp-action="Listar" class="nav-link text-white">
                        <i class="bi bi-people"></i> Estudiantes
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Usuarios" asp-action="Gestionar" class="nav-link text-white">
                        <i class="bi bi-person-gear"></i> Gestionar Usuarios
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Acceso" asp-action="Login" class="nav-link text-white">
                        <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                    </a>
                </li>
            </ul>
        </nav>

   
        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>
</body>
</html>