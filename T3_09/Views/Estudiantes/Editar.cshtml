@model T3_09.Models.Estudiante

@{
    ViewData["Title"] = "Editar Estudiante";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-3 overflow-hidden">

                <div class="card-header bg-warning bg-gradient text-dark text-center py-3">
                    <h3 class="fw-bold mb-0 text-uppercase">
                        <i class="bi bi-pencil-square me-2"></i> EDITAR ESTUDIANTE
                    </h3>
                    <p class="mb-0 small fw-bold opacity-75">Modificar información del registro académico</p>
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Editar">
                        <input type="hidden" asp-for="IdEstudiante" />

                        <h6 class="text-muted text-uppercase fw-bold mb-3 border-bottom pb-2">
                            <i class="bi bi-person-badge"></i> Datos Personales
                        </h6>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Nombre Completo</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-primary"><i class="bi bi-person-fill"></i></span>
                                <input asp-for="NombreCompleto" class="form-control border-start-0 ps-0" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">DNI</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-primary"><i class="bi bi-card-heading"></i></span>
                                    <input asp-for="Dni" class="form-control border-start-0 ps-0" required />
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">Fecha de Nacimiento</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-success"><i class="bi bi-calendar-check-fill"></i></span>
                                    <input asp-for="FechaNacimiento" type="date" class="form-control border-start-0 ps-0" required />
                                </div>
                            </div>
                        </div>

                        <h6 class="text-muted text-uppercase fw-bold mb-3 border-bottom pb-2 mt-3">
                            <i class="bi bi-house-door"></i> Ubicación y Familia
                        </h6>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Dirección</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-danger"><i class="bi bi-geo-alt-fill"></i></span>
                                <input asp-for="Direccion" class="form-control border-start-0 ps-0" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Apoderado</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-warning"><i class="bi bi-people-fill"></i></span>
                                <input asp-for="NombreApoderado" class="form-control border-start-0 ps-0" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5 pt-3 border-top">
                            <a asp-action="Listar" class="btn btn-outline-secondary px-4 fw-bold rounded-pill">
                                <i class="bi bi-x-lg"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold rounded-pill shadow-sm">
                                <i class="bi bi-check-circle-fill"></i> GUARDAR CAMBIOS
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>