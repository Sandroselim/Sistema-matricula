@model T3_09.Models.Estudiante
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Eliminar Estudiante</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="container mt-5">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4>Confirmar Eliminación</h4>
        </div>
        <div class="card-body">
            <h5 class="card-title text-center text-danger">¿Está seguro que desea eliminar este registro?</h5>
            <p class="text-center text-muted">Esta acción no se puede deshacer.</p>
            <hr />

            <dl class="row">
                <dt class="col-sm-3">Estudiante:</dt>
                <dd class="col-sm-9">@Model.NombreCompleto</dd>

                <dt class="col-sm-3">DNI:</dt>
                <dd class="col-sm-9">@Model.Dni</dd>

                <dt class="col-sm-3">Apoderado:</dt>
                <dd class="col-sm-9">@Model.NombreApoderado</dd>
            </dl>

            <form asp-action="Eliminar" class="text-center mt-4">
                <input type="hidden" asp-for="IdEstudiante" />
                <button type="submit" class="btn btn-danger">Sí, Eliminar</button>
                <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</body>
</html>