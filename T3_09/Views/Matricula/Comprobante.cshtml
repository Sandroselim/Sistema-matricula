@model T3_09.Models.Matricula
@{
    ViewData["Title"] = "Solicitud Registrada";
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/lottie-player/2.0.2/lottie-player.js"></script>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <div class="card shadow-lg border-0 rounded-3 overflow-hidden">

                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="fw-bold text-uppercase mb-0">
                        <i class="bi bi-hourglass-split"></i> Solicitud en Proceso
                    </h4>
                </div>

                <div class="card-body p-4 bg-white text-center">

                    <lottie-player src="https://assets2.lottiefiles.com/packages/lf20_osdxlbqq.json"
                                   background="transparent"
                                   speed="1"
                                   style="width: 120px; height: 120px; margin: 0 auto;"
                                   loop
                                   autoplay>
                    </lottie-player>

                    <h5 class="mt-3 fw-bold">Hemos recibido sus datos correctamente</h5>
                    <p class="text-muted">
                        Se ha generado una reserva de vacante para el alumno:
                        <br />
                        <strong class="text-dark fs-5">@Model.Estudiante.NombreCompleto</strong>
                    </p>

                    <div class="alert alert-secondary mt-4 mb-4">
                        <div class="row text-start">
                            <div class="col-6"><strong>Grado:</strong> @Model.Vacante.Grado</div>
                            <div class="col-6"><strong>Sección:</strong> @Model.Vacante.Seccion</div>
                            <div class="col-12 mt-2"><strong>Código de Trámite:</strong> @Model.CodigoPago</div>
                        </div>
                    </div>

                    <div class="border border-2 border-danger rounded p-3 bg-danger bg-opacity-10">
                        <h5 class="text-danger fw-bold text-uppercase mb-2">
                            <i class="bi bi-exclamation-circle-fill"></i> Instrucción Importante
                        </h5>
                        <p class="mb-0 fw-bold text-dark">
                            ACÉRQUESE A LA INSTITUCIÓN A REALIZAR SU MATRÍCULA Y EL PAGO CORRESPONDIENTE.
                        </p>
                        <small class="text-muted d-block mt-2">
                            Presente el código de trámite en secretaría para validar su registro.
                        </small>
                    </div>
                </div>
                <div class="card-footer bg-light p-3 text-center">
                    <a asp-controller="Acceso" asp-action="Login" class="btn btn-outline-dark">
                        <i class="bi bi-house"></i> Volver al Inicio
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>