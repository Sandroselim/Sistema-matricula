@{
    ViewData["Title"] = "Selección de Vacante";
    var vacantes = ViewBag.ListaVacantes as List<T3_09.Models.Vacante>;
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">Proceso de Matrícula 2025</h2>
        <p class="text-muted">Seleccione el grado y sección disponible para continuar.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["Error"]
        </div>
    }

    <div class="row">
        @if (vacantes != null && vacantes.Count > 0)
        {
            @foreach (var item in vacantes)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100 border-0">
                        <div class="card-header bg-primary text-white text-center">
                            <h5 class="mb-0">@item.Grado</h5>
                        </div>
                        <div class="card-body text-center">
                            <h6 class="card-title text-muted mb-3">Sección "@item.Seccion"</h6>

                            <div class="display-6 fw-bold text-dark mb-2">
                                @item.CuposDisponibles
                            </div>
                            <small class="text-uppercase text-muted fw-bold">Cupos Disponibles</small>

                            <hr />

                            <form asp-controller="Matricula" asp-action="CargarFormulario" method="post">
                                <input type="hidden" name="idVacante" value="@item.IdVacante" />

                                <button type="submit" class="btn btn-outline-primary w-100 rounded-pill">
                                    Seleccionar <i class="bi bi-arrow-right-circle"></i>
                                </button>
                            </form>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-warning text-center" role="alert">
                    <h4 class="alert-heading">No hay vacantes disponibles</h4>
                    <p>Lo sentimos, en este momento no hay cupos habilitados para matrícula.</p>
                </div>
            </div>
        }
    </div>
</div>