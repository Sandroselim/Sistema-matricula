@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Estadísticas Generales</h2>
<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total de Estudiantes</h5>
                <p class="card-text display-4">@ViewBag.TotalEstudiantes</p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Estudiantes por Grado</h5>
                <ul class="list-group">
                    @foreach (var item in ViewBag.TotalPorGrado)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @item.Grado
                            <span class="badge bg-primary rounded-pill">@item.Total</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>