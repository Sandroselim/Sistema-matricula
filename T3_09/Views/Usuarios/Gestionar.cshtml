@model T3_09.ViewModels.UsuarioVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Gestión de Usuarios</h2>

<div class="row">
    <div class="col-md-6">
        <h4>Crear Nuevo Usuario</h4>
        <form asp-action="CrearUsuario" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <input asp-for="Nombre" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Apellido</label>
                <input asp-for="Apellido" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input asp-for="Correo" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input asp-for="Contraseña" type="password" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Repetir Contraseña</label>
                <input asp-for="Repite_Contraseña" type="password" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Rol</label>
                <select asp-for="Id_Rol" class="form-select" asp-items="@(new SelectList(Model.Roles, "IdRol", "NomRol"))"></select>
            </div>
            <button type="submit" class="btn btn-success">Crear Usuario</button>
        </form>
    </div>

    <div class="col-md-6">
        <h4>Usuarios Existentes</h4>
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Acciones</th> 
                </tr>
            </thead>
            <tbody>
                @if (Model.Usuarios != null && Model.Usuarios.Any())
                {
                    @foreach (var usuario in Model.Usuarios)
                    {
                        <tr>
                            <td>@usuario.NomUsuario @usuario.ApeUsuario</td>
                            <td>@usuario.Correo</td>
                            <td>@usuario.Rol?.NomRol</td>
                            <td>
                 
                                <a asp-action="Editar" asp-route-id="@usuario.IdUsuario" class="btn btn-warning btn-sm">
                                    Editar
                                </a>
                               
                                <form asp-action="Eliminar" asp-route-id="@usuario.IdUsuario" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Está seguro de eliminar este usuario?');">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No hay usuarios disponibles.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>x
</div>